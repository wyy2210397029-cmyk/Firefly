---
import { commentConfig } from "@/config/commentConfig";
import { url } from "@/utils/url-utils";

interface Props {
	path: string;
}

const twikooConfig = commentConfig.twikoo ?? { envId: "" };
const jsUrl =
	twikooConfig.jsUrl ||
	"https://registry.npmmirror.com/twikoo/1.7.9/files/dist/twikoo.min.js";
const cssUrl = twikooConfig.cssUrl;
const normalizedPath =
	Astro.props.path.length > 1
		? Astro.props.path.replace(/\/+$/g, "")
		: Astro.props.path;
const config = {
	...twikooConfig,
	el: "#tcomment",
	path: normalizedPath,
};
---

<div id="tcomment"></div>
<script is:inline src={jsUrl} onerror="window.__twikooLoadError = true"></script>
{cssUrl && <link rel="stylesheet" href={cssUrl.startsWith("http") ? cssUrl : url(cssUrl)} />}
<script is:inline define:vars={{ config }}>
  let twikooRetryCount = 0;
  const maxTwikooRetries = 20;
  let twikooInitPromise = null;
  let initializedCommentEl = null;
  let initializedPath = "";

  function createTwikooConfig() {
    const envId =
      typeof config.envId === "string" && config.envId.startsWith("/")
        ? window.location.origin + config.envId
        : config.envId;

    return {
      envId,
      el: "#tcomment",
      path: config.path,
      lang: config.lang,
    };
  }

  function initTwikoo(force = false) {
    if (window.__twikooLoadError) {
      showTwikooError("Twikoo failed to load. Please refresh the page.");
      return;
    }

    const commentEl = document.getElementById("tcomment");
    if (!commentEl) return;

    const dynamicConfig = createTwikooConfig();
    const currentPath = dynamicConfig.path || window.location.pathname;

    if (!force && twikooInitPromise) return;
    if (!force && initializedCommentEl === commentEl && initializedPath === currentPath) return;

    if (typeof twikoo !== "undefined") {
      twikooRetryCount = 0;
      commentEl.innerHTML = "";

      twikooInitPromise = twikoo
        .init(dynamicConfig)
        .then(() => {
          initializedCommentEl = commentEl;
          initializedPath = currentPath;
        })
        .catch((error) => {
          console.error("[Twikoo] Failed to initialize:", error);
          showTwikooError("Twikoo failed to initialize. Please refresh the page.");
        })
        .finally(() => {
          twikooInitPromise = null;
        });
    } else {
      twikooRetryCount += 1;
      if (twikooRetryCount > maxTwikooRetries) {
        showTwikooError("Twikoo is still loading. Please refresh the page.");
        return;
      }
      setTimeout(initTwikoo, 500);
    }
  }

  function showTwikooError(message) {
    const commentEl = document.getElementById("tcomment");
    if (!commentEl) return;
    commentEl.innerHTML = '<div class="text-sm text-(--content-meta) py-4">' + message + "</div>";
  }

  document.addEventListener("DOMContentLoaded", initTwikoo);

  if (window.swup && window.swup.hooks) {
    window.swup.hooks.on("content:replace", function () {
      setTimeout(() => initTwikoo(true), 200);
    });
  } else {
    document.addEventListener("swup:enable", function () {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on("content:replace", function () {
          setTimeout(() => initTwikoo(true), 200);
        });
      }
    });
  }

  document.addEventListener("firefly:page:loaded", function () {
    const commentEl = document.getElementById("tcomment");
    if (commentEl) {
      initTwikoo();
    }
  });
</script>
